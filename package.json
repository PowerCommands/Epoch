{
  "name": "epoch",
  "version": "0.1.0",
  "description": "Webbläsarbaserat turordningsbaserat strategispel byggt med Phaser 3 + TypeScript + Vite.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run generate-manifests",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "prebuild": "npm run generate-manifests",
    "generate-manifests": "tsx scripts/generateSoundsManifest.ts && tsx scripts/generateMapManifest.ts && tsx scripts/generateNationManifest.ts",
    "generate-sprites": "tsx scripts/generateSprites.ts",
    "generate-resource-icons": "tsx scripts/generateResourceIcons.ts",
    "generate-sounds-manifest": "tsx scripts/generateSoundsManifest.ts",
    "generate-map-manifest": "tsx scripts/generateMapManifest.ts",
    "generate-nation-manifest": "tsx scripts/generateNationManifest.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "phaser": "^3.88.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
